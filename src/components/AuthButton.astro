---
// AuthButton — Sign in with Google / user avatar. Entirely client-side.
---

<div class="auth-btn-wrapper" id="auth-btn-wrapper" aria-live="polite">
  <!-- Filled by client-side script -->
</div>

<script>
  import { supabase } from '@/lib/supabase.ts';

  const wrapper = document.getElementById('auth-btn-wrapper')!;

  function renderUser(user: { user_metadata?: { avatar_url?: string; full_name?: string }; email?: string } | null) {
    if (user) {
      const name = user.user_metadata?.full_name || user.email || 'User';
      const avatar = user.user_metadata?.avatar_url;
      wrapper.innerHTML = `
        <div class="auth-user">
          ${avatar
            ? `<img src="${avatar}" alt="${name}" class="auth-avatar" width="28" height="28" />`
            : `<span class="auth-initials">${name[0].toUpperCase()}</span>`
          }
          <span class="auth-name">${name.split(' ')[0]}</span>
          <button class="auth-signout" id="auth-signout" aria-label="Sign out">Sign out</button>
        </div>
      `;
      document.getElementById('auth-signout')?.addEventListener('click', () => {
        supabase.auth.signOut();
      });
    } else {
      wrapper.innerHTML = `
        <button class="auth-signin" id="auth-signin">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.5"/>
            <path d="M2 14c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Sign in
        </button>
      `;
      document.getElementById('auth-signin')?.addEventListener('click', () => {
        // Always redirect back to the site root so the URL is predictable
        // and matches the pattern registered in Supabase's Redirect URLs list.
        const redirectTo = window.location.origin + import.meta.env.BASE_URL;
        supabase.auth.signInWithOAuth({
          provider: 'google',
          options: { redirectTo },
        });
      });
    }
  }

  // Initial state
  const { data: { session } } = await supabase.auth.getSession();
  renderUser(session?.user ?? null);

  // Keep in sync
  supabase.auth.onAuthStateChange((_event, session) => {
    renderUser(session?.user ?? null);
    window.dispatchEvent(new CustomEvent('auth-change', { detail: session }));
  });
</script>

<style is:global>
  #auth-btn-wrapper {
    display: flex;
    align-items: center;
  }

  #auth-btn-wrapper .auth-signin {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: var(--text-sm);
    color: white;
    background: var(--color-accent);
    border: none;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: opacity var(--transition-fast);
    white-space: nowrap;
  }

  #auth-btn-wrapper .auth-signin:hover {
    opacity: 0.88;
  }

  #auth-btn-wrapper .auth-user {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  #auth-btn-wrapper .auth-avatar {
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border);
  }

  #auth-btn-wrapper .auth-initials {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: var(--text-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  #auth-btn-wrapper .auth-name {
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
  }

  #auth-btn-wrapper .auth-signout {
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    background: none;
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  #auth-btn-wrapper .auth-signout:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-muted);
  }
</style>
