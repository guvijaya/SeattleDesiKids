---
const translators = [
  { language: 'English', name: 'Jayanthi Gowrishankaran', blog: 'https://seattledesikids.blogspot.com', color: 'var(--color-lang-en)' },
  { language: 'Hindi', name: 'Rahul Upadhyaya', blog: 'https://nanhihindi.blogspot.com', color: 'var(--color-lang-hi)' },
  { language: 'Telugu', name: 'Pavan Kumar Yerravelly', blog: 'https://seattletelugukids.blogspot.com', color: 'var(--color-lang-te)' },
  { language: 'Marathi', name: 'Anand Hinge & Mahesh Deshpande', blog: 'https://seattlemarathi.blogspot.com', color: 'var(--color-lang-mr)' },
  { language: 'Kannada', name: 'Lakshminarayanappa Thalagunda', blog: 'https://muddadakannada.blogspot.com', color: 'var(--color-lang-kn)' },
];
---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-grid">

      <!-- About the book -->
      <div class="footer-section">
        <h3 class="footer-heading">Seattle Desi Kids</h3>
        <p class="footer-text">
          A collection of children's essays about life in the Pacific Northwest,
          originally written in Tamil by <strong>Guruprasad Vijayarao</strong> and
          translated into five languages by a dedicated community of writers.
        </p>
        <p class="footer-text" style="margin-top: 0.75rem;">
          Published as a physical book and reviewed in local newspapers.
        </p>
        <div class="footer-book-links">
          <a
            href="https://www.amazon.com/dp/B09QJ7F4R6/"
            class="footer-book-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            Tamil edition on Amazon
          </a>
          <a
            href="https://a.co/d/0UCiYIm"
            class="footer-book-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            Hindi edition on Amazon
          </a>
        </div>
      </div>

      <!-- Translators -->
      <div class="footer-section">
        <h3 class="footer-heading">Translators</h3>
        <ul class="translator-list">
          {translators.map(t => (
            <li class="translator-item">
              <span class="lang-dot" style={`background: ${t.color}`} aria-hidden="true"></span>
              <div>
                <span class="translator-lang">{t.language}</span>
                <a href={t.blog} class="translator-name" target="_blank" rel="noopener noreferrer">
                  {t.name}
                </a>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-section">
        <h3 class="footer-heading">Contact</h3>
        <p class="footer-text">Questions or feedback? Reach the author directly.</p>
        <a href="mailto:guruprasad@seattledesikids.com" class="footer-contact-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M2 7l10 7 10-7"/>
          </svg>
          Email Guruprasad
        </a>
      </div>

    </div>

    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Guruprasad Vijayarao. All rights reserved.</p>
      <p>Essays in தமிழ், English, हिन्दी, తెలుగు, मराठी, ಕನ್ನಡ</p>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface-2);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-xl);
    margin-top: var(--space-xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }

  .footer-heading {
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-sm);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .footer-text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .footer-book-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-book-link,
  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-sm);
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    transition: color var(--transition-fast);
  }

  .footer-book-link:hover,
  .footer-contact-link:hover {
    color: var(--color-accent-hover);
  }

  .translator-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .translator-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
  }

  .lang-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.35rem;
  }

  .translator-lang {
    display: block;
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .translator-name {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .translator-name:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
</style>
