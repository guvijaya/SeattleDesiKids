---
import { LANGUAGES, LANGUAGE_ORDER, type LangCode } from '../utils/languages';
import PencilIllustration from './PencilIllustration.astro';
import ReadBadge from './ReadBadge.astro';

interface Props {
  slug: string;
  title: string;
  availableLanguages: LangCode[];
  defaultLang?: LangCode;
  illustration?: string;
  isFree?: boolean;
}

const {
  slug,
  title,
  availableLanguages,
  defaultLang = 'english',
  illustration,
  isFree = true,
} = Astro.props;

// Link to the first available language
const linkLang = availableLanguages.includes(defaultLang)
  ? defaultLang
  : availableLanguages[0];
const href = `${import.meta.env.BASE_URL}essays/${slug}/${linkLang}`;
---

<article class="essay-card">
  <a href={href} class="essay-card-link" aria-label={`Read "${title}"`}>

    <div class="essay-card-illustration">
      <PencilIllustration slug={slug} variant={1} />
      {!isFree && (
        <span class="essay-lock-badge" aria-label="Sign in to read" title="Sign in to read">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="2"/>
            <path d="M8 11V7a4 4 0 018 0v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </span>
      )}
    </div>

    <div class="essay-card-body">
      <div class="essay-card-title-row">
        <h2 class="essay-card-title">{title}</h2>
        <ReadBadge slug={slug} />
      </div>

      <div class="essay-card-langs" aria-label="Available languages">
        {LANGUAGE_ORDER.map(lang => {
          const info = LANGUAGES[lang];
          const available = availableLanguages.includes(lang);
          return (
            <span
              class:list={['lang-pill', { 'lang-pill--available': available, 'lang-pill--unavailable': !available }]}
              style={available ? `background: ${info.color}` : ''}
              title={`${info.label}: ${available ? 'Available' : 'Not available'}`}
              aria-hidden="true"
            />
          );
        })}
        <span class="lang-pill-label">
          {availableLanguages.length} language{availableLanguages.length !== 1 ? 's' : ''}
        </span>
      </div>
    </div>

  </a>
</article>

<style>
  .essay-card {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .essay-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
  }

  .essay-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
  }

  .essay-card-illustration {
    position: relative;
    height: 160px;
    overflow: hidden;
    background: var(--color-surface-2);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .essay-lock-badge {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(0, 0, 0, 0.55);
    color: white;
    border-radius: 50%;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .essay-card-title-row {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .essay-card-title-row .essay-card-title {
    flex: 1;
  }

  .essay-card-illustration :global(svg) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .essay-card-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }

  .essay-card-title {
    font-family: 'Lora', serif;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .essay-card-langs {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: auto;
  }

  .lang-pill {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .lang-pill--available {
    opacity: 1;
  }

  .lang-pill--unavailable {
    background: var(--color-border);
    opacity: 0.5;
  }

  .lang-pill-label {
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-left: 0.25rem;
  }
</style>

<script>
  import { supabase } from '@/lib/supabase.ts';

  function updateLockBadges(loggedIn: boolean) {
    document.querySelectorAll<HTMLElement>('.essay-lock-badge').forEach(el => {
      el.style.display = loggedIn ? 'none' : '';
    });
  }

  const { data: { session } } = await supabase.auth.getSession();
  updateLockBadges(!!session);

  supabase.auth.onAuthStateChange((_event, session) => {
    updateLockBadges(!!session);
  });
</script>
