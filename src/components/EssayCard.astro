---
import { LANGUAGES, LANGUAGE_ORDER, type LangCode } from '../utils/languages';
import PencilIllustration from './PencilIllustration.astro';
import ReadBadge from './ReadBadge.astro';

interface Props {
  slug: string;
  title: string;
  displayTitles?: Record<string, string>;
  availableLanguages: LangCode[];
  defaultLang?: LangCode;
  illustration?: string;
  isFree?: boolean;
}

const {
  slug,
  title,
  displayTitles = {},
  availableLanguages,
  defaultLang = 'english',
  illustration,
  isFree = true,
} = Astro.props;

// Link to the first available language
const linkLang = availableLanguages.includes(defaultLang)
  ? defaultLang
  : availableLanguages[0];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = `${base}/essays/${slug}/${linkLang}`;
const initialTitle = displayTitles[linkLang] ?? title;
---

<article class="essay-card">

  <!-- Clickable area: illustration + title -->
  <a href={href} class="essay-card-link" aria-label={`Read "${initialTitle}"`}>

    <div class="essay-card-illustration">
      <PencilIllustration slug={slug} variant={1} />
      {!isFree && (
        <span class="essay-lock-badge" aria-label="Sign in to read" title="Sign in to read">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="2"/>
            <path d="M8 11V7a4 4 0 018 0v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </span>
      )}
    </div>

    <div class="essay-card-body">
      <div class="essay-card-title-row">
        <h2 class="essay-card-title">{initialTitle}</h2>
        <ReadBadge slug={slug} />
      </div>
    </div>

  </a>

  <!-- Language pills — outside the <a> so buttons are valid HTML -->
  <div class="essay-card-langs" aria-label="Available languages">
    {LANGUAGE_ORDER.map(lang => {
      const info = LANGUAGES[lang];
      const available = availableLanguages.includes(lang);
      const isActive = lang === linkLang;
      const langTitle = displayTitles[lang] ?? title;
      const langHref = `${base}/essays/${slug}/${lang}`;
      const langFont = info.font ? `'${info.font}', serif` : "'Lora', serif";

      return available ? (
        <button
          class:list={['lang-pill', 'lang-pill--available', { 'lang-pill--active': isActive }]}
          style={`--pill-color: ${info.color}`}
          data-title={langTitle}
          data-href={langHref}
          data-htmllang={info.htmlLang}
          data-font={langFont}
          aria-pressed={isActive ? 'true' : 'false'}
          title={info.label}
        >
          {info.nativeLabel}
        </button>
      ) : (
        <span
          class="lang-pill lang-pill--unavailable"
          style={`--pill-color: ${info.color}`}
          title={`Not yet in ${info.label}`}
          aria-hidden="true"
        >
          {info.nativeLabel}
        </span>
      );
    })}
  </div>

</article>

<style>
  .essay-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .essay-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
  }

  .essay-card-link {
    display: flex;
    flex-direction: column;
    flex: 1;
    color: inherit;
  }

  .essay-card-illustration {
    position: relative;
    height: 160px;
    overflow: hidden;
    background: var(--color-surface-2);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .essay-lock-badge {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(0, 0, 0, 0.55);
    color: white;
    border-radius: 50%;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .essay-card-title-row {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .essay-card-title-row .essay-card-title {
    flex: 1;
  }

  .essay-card-illustration :global(svg) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .essay-card-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }

  .essay-card-title {
    font-family: 'Lora', serif;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  /* Language pill strip at the bottom of the card */
  .essay-card-langs {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.3rem;
    padding: var(--space-sm) var(--space-md);
    border-top: 1px solid var(--color-border);
    background: var(--color-surface-2);
  }

  .lang-pill {
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-xs);
    font-weight: 700;
    padding: 0.2rem 0.55rem;
    border-radius: 100px;
    border: 1.5px solid transparent;
    white-space: nowrap;
    line-height: 1.4;
  }

  .lang-pill--available {
    background: color-mix(in srgb, var(--pill-color) 12%, transparent);
    color: var(--pill-color);
    border-color: color-mix(in srgb, var(--pill-color) 25%, transparent);
    cursor: pointer;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .lang-pill--available:hover {
    background: color-mix(in srgb, var(--pill-color) 22%, transparent);
  }

  .lang-pill--active {
    background: var(--pill-color) !important;
    color: white !important;
    border-color: var(--pill-color) !important;
  }

  .lang-pill--unavailable {
    background: transparent;
    color: var(--color-text-muted);
    border-color: var(--color-border);
    opacity: 0.5;
    cursor: default;
  }
</style>

<script>
  import { supabase } from '@/lib/supabase.ts';

  // --- Language pill switching ---
  document.querySelectorAll<HTMLElement>('.essay-card').forEach(card => {
    const titleEl = card.querySelector<HTMLElement>('.essay-card-title');
    const linkEl = card.querySelector<HTMLAnchorElement>('.essay-card-link');
    if (!titleEl || !linkEl) return;

    card.querySelectorAll<HTMLButtonElement>('button.lang-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        const newTitle = pill.dataset.title ?? '';
        const newHref = pill.dataset.href ?? '';
        const newLang = pill.dataset.htmllang ?? 'en';
        const newFont = pill.dataset.font ?? "'Lora', serif";

        titleEl.textContent = newTitle;
        titleEl.lang = newLang;
        titleEl.style.fontFamily = newFont;

        linkEl.href = newHref;
        linkEl.setAttribute('aria-label', `Read "${newTitle}"`);

        card.querySelectorAll<HTMLButtonElement>('button.lang-pill').forEach(p => {
          p.classList.remove('lang-pill--active');
          p.setAttribute('aria-pressed', 'false');
        });
        pill.classList.add('lang-pill--active');
        pill.setAttribute('aria-pressed', 'true');
      });
    });
  });

  // --- Lock badge visibility ---
  function updateLockBadges(loggedIn: boolean) {
    document.querySelectorAll<HTMLElement>('.essay-lock-badge').forEach(el => {
      el.style.display = loggedIn ? 'none' : '';
    });
  }

  const { data: { session } } = await supabase.auth.getSession();
  updateLockBadges(!!session);

  supabase.auth.onAuthStateChange((_event, session) => {
    updateLockBadges(!!session);
  });
</script>
