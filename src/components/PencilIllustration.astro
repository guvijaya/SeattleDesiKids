---
interface Props {
  slug: string;
  variant?: 1 | 2;
  class?: string;
}

const { slug, variant = 1, class: className } = Astro.props;

// Direct slug → scene mapping (checked first, most specific)
const slugSceneMap: Record<string, string> = {
  'escape-room':            'escape',
  'halloween':              'halloween',
  'idylwood-beach-park':    'beach',
  'marymoor-park':          'football',
  'potluck':                'potluck',
  'sammamish-river-trail':  'riverside',
  'boat-ride':              'boat',
  'farmers-market':         'market',
  'train-journey':          'monorail',
  'train':                  'longtrain',
  'school-bus':             'transport',
  'birthday-party':         'celebration',
  'gardening':              'garden',
  'sammamish-lake-trail':   'laketrail',
  'franklin-falls':         'waterfall',
  'sunrise-mt-rainier':     'nature',
  'snow-day':               'snow',
  'an-outing':              'trail',
  'get-started':            'phone',
  'higher-secondary-schools-world-language-credits': 'school',
};

function getScene(slug: string): string {
  if (slugSceneMap[slug]) return slugSceneMap[slug];
  if (/boat|ride/i.test(slug)) return 'boat';
  if (/market|farmer/i.test(slug)) return 'market';
  if (/escape/i.test(slug)) return 'escape';
  if (/halloween/i.test(slug)) return 'halloween';
  if (/beach|idyl/i.test(slug)) return 'beach';
  if (/marymoor|football/i.test(slug)) return 'football';
  if (/potluck/i.test(slug)) return 'potluck';
  if (/river.*trail|riverside/i.test(slug)) return 'riverside';
  if (/sunrise|mountain|rainier|falls|franklin|lake|sammamish|snow/i.test(slug)) return 'nature';
  if (/trail|path|walk|hike/i.test(slug)) return 'trail';
  if (/train|bus|journey|travel/i.test(slug)) return 'transport';
  if (/garden|park|flower/i.test(slug)) return 'garden';
  if (/birthday|party|celebration/i.test(slug)) return 'celebration';
  if (/school|language|credit|learn|study/i.test(slug)) return 'school';
  return 'book';
}

const scene = getScene(slug);

