---
/**
 * ReadBadge — a small ✓ checkmark shown on essay cards the user has read.
 * Placed in each EssayCard; the script runs once (Astro deduplicates it)
 * and updates all badges on the page in one Supabase query.
 */
interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<span
  class="read-badge"
  data-slug={slug}
  aria-label="You've read this essay"
  style="display:none"
>
  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
    <path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  Read
</span>

<script>
  import { supabase } from '@/lib/supabase.ts';

  async function syncReadBadges(userId: string | null) {
    const badges = document.querySelectorAll<HTMLElement>('.read-badge');
    if (!badges.length) return;

    // Hide all first
    badges.forEach(b => (b.style.display = 'none'));

    if (!userId) return;

    const { data } = await supabase
      .from('reading_progress')
      .select('slug')
      .eq('user_id', userId);

    if (!data?.length) return;

    const readSlugs = new Set(data.map((r: { slug: string }) => r.slug));
    badges.forEach(badge => {
      if (readSlugs.has(badge.dataset.slug!)) {
        badge.style.display = '';
      }
    });
  }

  const { data: { session } } = await supabase.auth.getSession();
  await syncReadBadges(session?.user?.id ?? null);

  supabase.auth.onAuthStateChange(async (_event, session) => {
    await syncReadBadges(session?.user?.id ?? null);
  });
</script>

<style>
  .read-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-xs);
    font-weight: 700;
    color: #16a34a;
    background: #dcfce7;
    border-radius: 999px;
    padding: 0.15rem 0.45rem;
    flex-shrink: 0;
  }
</style>
