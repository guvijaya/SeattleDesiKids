---
import { LANGUAGES, LANGUAGE_ORDER, type LangCode } from '../utils/languages';

interface Props {
  currentLang: LangCode;
  slug: string;
  availableLanguages: LangCode[];
}

const { currentLang, slug, availableLanguages } = Astro.props;
---

<nav class="lang-switcher" aria-label="Language switcher">
  <ul class="lang-tabs">
    {LANGUAGE_ORDER.map((lang) => {
      const info = LANGUAGES[lang];
      const isAvailable = availableLanguages.includes(lang);
      const isCurrent = lang === currentLang;

      return (
        <li>
          {isAvailable ? (
            <a
              href={`${import.meta.env.BASE_URL}essays/${slug}/${lang}`}
              class:list={['lang-tab', { active: isCurrent, available: !isCurrent }]}
              style={`--tab-color: ${info.color}`}
              aria-current={isCurrent ? 'page' : undefined}
              data-lang={lang}
              data-slug={slug}
            >
              <span class="lang-tab-native">{info.nativeLabel}</span>
            </a>
          ) : (
            <span
              class="lang-tab unavailable"
              aria-disabled="true"
              title={`Not yet translated to ${info.label}`}
            >
              <span class="lang-tab-native">{info.nativeLabel}</span>
            </span>
          )}
        </li>
      );
    })}
  </ul>
</nav>

<!-- Scroll position preservation script -->
<script>
  // Save scroll position before navigating away
  document.querySelectorAll<HTMLAnchorElement>('.lang-tab[data-lang]').forEach(link => {
    link.addEventListener('click', () => {
      const slug = link.dataset.slug;
      if (slug) {
        sessionStorage.setItem(`scroll:${slug}`, String(window.scrollY));
      }
    });
  });

  // Restore scroll position on load
  const slug = document.querySelector<HTMLElement>('.lang-tab[data-slug]')?.dataset.slug;
  if (slug) {
    const saved = sessionStorage.getItem(`scroll:${slug}`);
    if (saved) {
      // Use requestAnimationFrame to ensure DOM is painted first
      requestAnimationFrame(() => {
        window.scrollTo({ top: parseInt(saved, 10), behavior: 'instant' });
      });
      sessionStorage.removeItem(`scroll:${slug}`);
    }
  }
</script>

<style>
  .lang-switcher {
    max-width: var(--reader-width);
    margin-inline: auto;
    margin-bottom: var(--space-lg);
  }

  .lang-tabs {
    display: flex;
    gap: 0.375rem;
    padding: 0.375rem;
    background: var(--color-surface-2);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .lang-tab {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    border-radius: calc(var(--radius-md) - 4px);
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-sm);
    font-weight: 600;
    transition: background-color var(--transition-fast), color var(--transition-fast);
    white-space: nowrap;
    min-width: 80px;
  }

  a.lang-tab.active {
    background: var(--tab-color, var(--color-accent));
    color: white;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
  }

  a.lang-tab.available {
    color: var(--color-text-secondary);
  }

  a.lang-tab.available:hover {
    background: var(--color-surface);
    color: var(--color-text-primary);
  }

  .lang-tab.unavailable {
    color: var(--color-text-muted);
    cursor: not-allowed;
    opacity: 0.5;
    user-select: none;
  }

  .lang-tab-native {
    font-size: var(--text-sm);
  }
</style>
