---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Read gallery images from public/images/gallery/ at build time
const galleryDir = path.join(process.cwd(), 'public', 'images', 'gallery');
const imageExts = new Set(['.jpg', '.jpeg', '.png', '.webp', '.gif']);
const galleryImages = fs.existsSync(galleryDir)
  ? fs.readdirSync(galleryDir)
      .filter(f => imageExts.has(path.extname(f).toLowerCase()))
      .sort()
  : [];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const translators = [
  { language: 'English', name: 'Jayanthi Gowrishankaran', blog: 'https://seattledesikids.blogspot.com', color: 'var(--color-lang-en)' },
  { language: 'Hindi', name: 'Rahul Upadhyaya', blog: 'https://nanhihindi.blogspot.com', color: 'var(--color-lang-hi)' },
  { language: 'Telugu', name: 'Pavan Kumar Yerravelly', blog: 'https://seattletelugukids.blogspot.com', color: 'var(--color-lang-te)' },
  { language: 'Marathi', name: 'Anand Hinge & Mahesh Deshpande', blog: 'https://seattlemarathi.blogspot.com', color: 'var(--color-lang-mr)' },
  { language: 'Kannada', name: 'Lakshminarayanappa Thalagunda', blog: 'https://muddadakannada.blogspot.com', color: 'var(--color-lang-kn)' },
];
---

<BaseLayout
  title="About"
  description="About Seattle Desi Kids — a multilingual children's essay collection by Guruprasad Vijayarao."
>
  <div class="container">
    <article class="about-page prose">
      <h1>About Seattle Desi Kids</h1>

      <p>
        <em>Seattle Desi Kids</em> is a collection of children's essays about growing up and exploring
        life in the Pacific Northwest. Originally written in <em>Tamil</em> by
        <em>Guruprasad Vijayarao</em>, these stories have been lovingly translated into
        five languages by a community of dedicated writers from the Seattle diaspora.
      </p>

      <p>
      For many children growing up outside India, learning their mother tongue can be challenging—especially when most books focus only on stories and settings from back home. While those cultural treasures are invaluable, young readers abroad often connect more easily with stories from their own surroundings. 
      This Kids Book changes that. It brings local experiences and familiar events into the heart of language learning, making it engaging and relatable for children. Available in Tamil, Kannada, Telugu, Hindi, and Martathi, it’s designed to help kids embrace their heritage language with joy and confidence.

<p><strong>What Makes This Kids Book Special?</strong></p>
<ul>
<li>
Relatable, Everyday Language: Uses simple, conversational words that children hear in daily life, making learning more natural and fun.
</li><li>Local Activities: Ten essays on familiar and easy-to-understand topics.Seven travel-themed stories set right here in Washington and Seattle.The travel stories spark curiosity and make reading interactive—especially when children read them aloud to grandparents or parents, encouraging conversations about both local life and cultural roots.
</li><li>More Than Just Language: Some essays even touch on global language assessments, offering helpful insights for older children preparing for language exams.
</li><li>A Book for the Whole Family: This Kids Book isn’t just for children—it’s a bridge between generations and cultures. Parents, grandparents, teachers, and community members will find it a valuable resource for nurturing both language skills and cultural connection.</li>
</ul>
      <p>
        The book available as a print version too. Please reach out to Guru for copies.
      </p>

      <h2>Join as a Translator</h2>
      <p>
        We warmly welcome translators who can bring these stories to more languages! The goal is
        simple — make language learning fun and accessible for children everywhere.
      </p>
      <p>
	If your language is not yet included and you would like to help, we would love to hear from you. Each new translation becomes a meaningful gift for a child reconnecting with their heritage language. While AI handles much of the initial translation, we rely on native speakers to review and refine it with care.
      </p>

      <h2>The Translators</h2>
      <p>A heartfelt thank you to all the translators who made these stories accessible in multiple languages:</p>

      <div class="translator-cards">
        {translators.map(t => (
          <div class="translator-card">
            <div class="translator-lang-badge" style={`background: color-mix(in srgb, ${t.color} 15%, transparent); color: ${t.color}; border-color: color-mix(in srgb, ${t.color} 30%, transparent)`}>
              {t.language}
            </div>
            <a href={t.blog} target="_blank" rel="noopener noreferrer" class="translator-name-link">
              {t.name}
            </a>
          </div>
        ))}
      </div>
    </article>

    {galleryImages.length > 0 && (
      <section class="gallery-section" aria-label="Photo gallery">
        <h2 class="gallery-heading">Gallery</h2>
        <div
          class="gallery-grid"
          id="gallery-grid"
          data-images={JSON.stringify(galleryImages.map(f => `${base}/images/gallery/${f}`))}
        >
          {galleryImages.map((img, i) => (
            <button class="gallery-item" data-index={String(i)} aria-label={`View photo ${i + 1}`}>
              <img
                src={`${base}/images/gallery/${img}`}
                alt=""
                loading="lazy"
                class="gallery-thumb"
              />
            </button>
          ))}
        </div>
      </section>
    )}

  </div>

  <!-- Lightbox (always in DOM, toggled via hidden attribute) -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <button class="lb-close" id="lb-close" aria-label="Close">✕</button>
    <button class="lb-prev"  id="lb-prev"  aria-label="Previous photo">&#8249;</button>
    <img class="lb-img" id="lb-img" src="" alt="" />
    <button class="lb-next"  id="lb-next"  aria-label="Next photo">&#8250;</button>
  </div>

</BaseLayout>

<style>
  .about-page {
    padding-block: var(--space-xl);
    max-width: var(--reader-width);
    margin-inline: auto;
  }

  .book-link {
    display: inline-block;
    background: var(--color-accent);
    color: white !important;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-sm);
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: var(--text-sm);
    text-decoration: none !important;
    transition: background-color var(--transition-fast);
  }

  .book-link:hover {
    background: var(--color-accent-hover);
  }

  .translator-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .translator-card {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .translator-lang-badge {
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-xs);
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    border: 1.5px solid;
    white-space: nowrap;
  }

  .translator-name-link {
    font-size: var(--text-base);
    color: var(--color-text-primary);
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .translator-name-link:hover {
    color: var(--color-accent);
  }

  /* ── Gallery ── */
  .gallery-section {
    max-width: 1200px;
    margin-inline: auto;
    padding-bottom: var(--space-xl);
  }

  .gallery-heading {
    font-family: 'Lora', serif;
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.5rem;
  }

  .gallery-item {
    display: block;
    padding: 0;
    border: none;
    background: var(--color-surface-2);
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 1;
    transition: opacity var(--transition-fast);
  }

  .gallery-item:hover {
    opacity: 0.85;
  }

  .gallery-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Lightbox ── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] { display: none; }

  .lb-img {
    max-width: min(90vw, 1000px);
    max-height: 88vh;
    object-fit: contain;
    border-radius: var(--radius-sm);
    user-select: none;
  }

  .lb-close,
  .lb-prev,
  .lb-next {
    position: absolute;
    background: rgba(255,255,255,0.12);
    border: none;
    color: white;
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition-fast);
    line-height: 1;
  }

  .lb-close,
  .lb-prev,
  .lb-next {
    background: rgba(255,255,255,0.12);
  }
  .lb-close:hover, .lb-prev:hover, .lb-next:hover {
    background: rgba(255,255,255,0.25);
  }

  .lb-close {
    top: 1rem; right: 1rem;
    width: 2.5rem; height: 2.5rem;
    font-size: 1.1rem;
  }

  .lb-prev, .lb-next {
    top: 50%; transform: translateY(-50%);
    width: 3rem; height: 3rem;
    font-size: 2rem;
  }

  .lb-prev { left: 1rem; }
  .lb-next { right: 1rem; }
</style>

<script>
  const grid     = document.getElementById('gallery-grid');
  const lightbox = document.getElementById('lightbox');
  const lbImg    = document.getElementById('lb-img') as HTMLImageElement;
  const lbClose  = document.getElementById('lb-close');
  const lbPrev   = document.getElementById('lb-prev');
  const lbNext   = document.getElementById('lb-next');

  if (grid && lightbox && lbImg) {
    const images: string[] = JSON.parse(grid.dataset.images || '[]');
    let current = 0;

    function show(index: number) {
      current = (index + images.length) % images.length;
      lbImg.src = images[current];
      lightbox.removeAttribute('hidden');
      lbClose?.focus();
    }

    function close() {
      lightbox.setAttribute('hidden', '');
      lbImg.src = '';
    }

    // Open on thumbnail click
    grid.querySelectorAll<HTMLButtonElement>('.gallery-item').forEach(btn => {
      btn.addEventListener('click', () => show(Number(btn.dataset.index)));
    });

    lbClose?.addEventListener('click', close);
    lbPrev?.addEventListener('click', () => show(current - 1));
    lbNext?.addEventListener('click', () => show(current + 1));

    // Click backdrop to close
    lightbox.addEventListener('click', e => { if (e.target === lightbox) close(); });

    // Keyboard navigation
    document.addEventListener('keydown', e => {
      if (lightbox.hasAttribute('hidden')) return;
      if (e.key === 'Escape')      close();
      if (e.key === 'ArrowLeft')   show(current - 1);
      if (e.key === 'ArrowRight')  show(current + 1);
    });
  }
</script>
