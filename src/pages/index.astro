---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';
import { type LangCode } from '../utils/languages';
import { FREE_ESSAY_SLUGS } from '../lib/freeEssays';
import fs from 'node:fs';
import path from 'node:path';

// Load all essays from the content/essays directory
const essaysDir = path.join(process.cwd(), 'src', 'content', 'essays');

interface EssayMeta {
  slug: string;
  englishTitle: string;
  displayTitles: Record<string, string>;
  availableLanguages: LangCode[];
  illustration?: string;
}

let essays: EssayMeta[] = [];

if (fs.existsSync(essaysDir)) {
  const slugs = fs.readdirSync(essaysDir).filter(name => {
    return fs.statSync(path.join(essaysDir, name)).isDirectory();
  });

  for (const slug of slugs) {
    const metaPath = path.join(essaysDir, slug, 'metadata.json');
    if (fs.existsSync(metaPath)) {
      const meta = JSON.parse(fs.readFileSync(metaPath, 'utf-8'));
      essays.push({
        slug: meta.slug,
        englishTitle: meta.englishTitle,
        displayTitles: meta.displayTitles || {},
        availableLanguages: meta.availableLanguages || [],
        illustration: meta.illustrations?.[0],
      });
    }
  }
}

// Sort by number of available languages (most first), then alphabetically
essays.sort((a, b) => {
  const diff = b.availableLanguages.length - a.availableLanguages.length;
  if (diff !== 0) return diff;
  return a.englishTitle.localeCompare(b.englishTitle);
});
---

<BaseLayout
  title="Seattle Desi Kids"
  description="Children's essays in 5 languages — English, Hindi, Telugu, Marathi and Kannada. Original essays by Guruprasad Vijayarao."
  additionalFonts={[
    'Noto Serif Tamil:wght@400;600',
    'Noto Serif Devanagari:wght@400;600',
    'Noto Serif Telugu:wght@400;600',
    'Noto Serif Kannada:wght@400;600',
  ]}
>
  <div class="container">
    <section class="hero">
      <p class="hero-subtitle">
        A collection of children's essays about life in the Pacific Northwest.
      </p>
      <div class="hero-langs" role="group" aria-label="Filter by language">
        <button class="hero-lang" data-lang="tamil" style="--lang-color: var(--color-lang-ta)" aria-pressed="false">
          <span class="hero-lang-native">தமிழ்</span>
          <span class="hero-lang-english">Tamil</span>
        </button>
        <button class="hero-lang" data-lang="english" style="--lang-color: var(--color-lang-en)" aria-pressed="false">
          <span class="hero-lang-native">English</span>
          <span class="hero-lang-english">English</span>
        </button>
        <button class="hero-lang" data-lang="hindi" style="--lang-color: var(--color-lang-hi)" aria-pressed="false">
          <span class="hero-lang-native">हिन्दी</span>
          <span class="hero-lang-english">Hindi</span>
        </button>
        <button class="hero-lang" data-lang="telugu" style="--lang-color: var(--color-lang-te)" aria-pressed="false">
          <span class="hero-lang-native">తెలుగు</span>
          <span class="hero-lang-english">Telugu</span>
        </button>
        <button class="hero-lang" data-lang="marathi" style="--lang-color: var(--color-lang-mr)" aria-pressed="false">
          <span class="hero-lang-native">मराठी</span>
          <span class="hero-lang-english">Marathi</span>
        </button>
        <button class="hero-lang" data-lang="kannada" style="--lang-color: var(--color-lang-kn)" aria-pressed="false">
          <span class="hero-lang-native">ಕನ್ನಡ</span>
          <span class="hero-lang-english">Kannada</span>
        </button>
      </div>
    </section>

    {essays.length > 0 ? (
      <section class="essays-section">
        <h2 class="section-heading">All Essays <span class="essay-count" id="essay-count"></span></h2>
        <div class="essay-grid">
          {essays.map(essay => (
            <EssayCard
              slug={essay.slug}
              title={essay.englishTitle}
              displayTitles={essay.displayTitles}
              availableLanguages={essay.availableLanguages}
              illustration={essay.illustration}
              isFree={FREE_ESSAY_SLUGS.includes(essay.slug)}
            />
          ))}
        </div>
      </section>
    ) : (
      <section class="empty-state">
        <p>Essays are being prepared. Check back soon!</p>
        <p class="empty-hint">Run <code>python scripts/scrape_blogs.py</code> to load content.</p>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding-top: var(--space-md);
    padding-bottom: var(--space-md);
    max-width: 680px;
    margin-inline: auto;
  }

  .hero-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .hero-langs {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .hero-lang {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    /* button reset */
    background: none;
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .hero-lang:hover {
    background: color-mix(in srgb, var(--lang-color) 8%, transparent);
    border-color: color-mix(in srgb, var(--lang-color) 30%, transparent);
  }

  .hero-lang[aria-pressed="true"] {
    background: color-mix(in srgb, var(--lang-color) 12%, transparent);
    border-color: var(--lang-color);
  }

  .hero-lang-native {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--lang-color);
  }

  .hero-lang-english {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .essays-section {
    padding-bottom: var(--space-xl);
  }

  .essay-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-xl);
    color: var(--color-text-secondary);
  }

  .empty-hint {
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .empty-hint code {
    background: var(--color-surface-2);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875em;
  }

  .section-heading {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .essay-count {
    font-family: 'Nunito', sans-serif;
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text-muted);
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.hero-lang');
  const cards = document.querySelectorAll<HTMLElement>('.essay-card');
  const countEl = document.getElementById('essay-count');

  function updateCount() {
    const visible = [...cards].filter(c => c.style.display !== 'none').length;
    if (countEl) {
      countEl.textContent = visible < cards.length ? `(${visible} of ${cards.length})` : `(${cards.length})`;
    }
  }

  updateCount();

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.dataset.lang!;
      const isActive = btn.getAttribute('aria-pressed') === 'true';

      // Deselect all buttons
      buttons.forEach(b => b.setAttribute('aria-pressed', 'false'));

      if (isActive) {
        // Toggle off — show everything
        cards.forEach(card => card.style.removeProperty('display'));
      } else {
        // Filter to this language
        btn.setAttribute('aria-pressed', 'true');
        cards.forEach(card => {
          const langs = card.dataset.langs?.split(',') ?? [];
          card.style.display = langs.includes(lang) ? '' : 'none';
        });
      }

      updateCount();
    });
  });
</script>
